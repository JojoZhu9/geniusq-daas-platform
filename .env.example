# 默认模式可完全离线完成所有验收路径
LLM_MODE=offline

# DeepSeek Text-to-SQL 模式。真实密钥只放本地 .env，不要提交到 Git
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30

# 预留 OpenAI 兼容模型配置；密钥只由后端读取
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# 本地状态与查询安全边界
DATABASE_URL=sqlite:///./daas_demo.db
QUERY_ROW_LIMIT=500
